--header "\n {file}\n MarkersExtractor • https://github.com/TheAcharya/MarkersExtractor\n Licensed under MIT License\n"
--maxwidth 140
--allow-partial-wrapping false
--call-site-paren balanced
--complex-attributes prev-line
--computed-var-attributes prev-line
--empty-braces spaced
--extension-acl on-declarations
--func-attributes prev-line
--stored-var-attributes prev-line
--strip-unused-args unnamed-only
--trailing-commas never
--disable docComments,redundantMemberwiseInit,redundantPattern,redundantRawValues,redundantSendable,redundantSwiftTestingSuite,redundantVariable,swiftTestingTestCaseNames,unusedArguments
--enable preferSwiftTesting,wrapMultilineFunctionChains